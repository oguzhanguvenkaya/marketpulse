# MarketPulse Environment Configuration
# Copy this file to .env and fill in your values.

# === Required ===

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Internal API key for backend auth
INTERNAL_API_KEY="your-internal-api-key"

# === Scraping / Proxy ===

# ScraperAPI key (canonical name — legacy SCRAPPER_API also accepted)
SCRAPER_API_KEY="your-scraperapi-key"

# Bright Data proxy credentials
BRIGHT_DATA_ACCOUNT_ID=""
BRIGHT_DATA_ZONE_PASSWORD=""
BRIGHT_DATA_ZONE_NAME=""

# Proxy provider selection: "auto" | "scraperapi" | "brightdata"
# PROXY_PROVIDER="auto"

# === AI ===

# OpenAI API key (for transcript summaries)
OPENAI_API_KEY=""

# === Optional ===

# CORS origins (comma-separated). Replit domains are auto-detected.
# CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Price monitor executor: "local" (single process) or "celery" (distributed)
# PRICE_MONITOR_EXECUTOR="celery"

# Max concurrent price monitor requests
# PRICE_MONITOR_MAX_CONCURRENT_REQUESTS=40

# Database pool settings
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT_SECONDS=30
# DB_POOL_RECYCLE_SECONDS=180

# Debug: save raw HTML responses to disk (default: false)
# DEBUG_SAVE_HTML=false
# DEBUG_HTML_PATH="/tmp/scraping_debug"
